// !Parent waiting\nParent got exit status: 9

int main(str *args) {
    int pid = fork()

    if (pid == 0) {
        sleep(2)
        return 9
    } else {
        // Parent process
        println("Parent waiting")
        int status = pid.wait()
        println("Parent got exit status: " + str(status))
    }
    return 0
}
